{
  "providers": {
    "fireworks": {
      "baseUrl": "https://api.fireworks.ai/inference/v1",
      "apiKey": "$FIREWORKS_API_KEY"
    }
  },
  "models": {
    "kimi": {
      "provider": "fireworks",
      "model": "accounts/fireworks/models/kimi-k2p6",
      "maxTokens": 32768,
      "temperature": 0
    }
  },
  "defaultModel": "kimi",
  "webhooks": {
    "ci": {
      "workflow": "ci",
      "auth": "bearer",
      "secret": "$CI_WEBHOOK_SECRET"
    }
  },
  "observability": {
    "enabled": false,
    "otlpEndpoint": "https://otlp-gateway-prod-<region>.grafana.net/otlp",
    "headers": {
      "Authorization": "Basic $GRAFANA_CLOUD_OTLP_TOKEN"
    }
  },
  "datasources": {
    "grafana": {
      "baseUrl": "https://<stack>.grafana.net",
      "token": "$SERVICE_ACCOUNT_TOKEN",
      "tokenEnv": "SERVICE_ACCOUNT_TOKEN"
    }
  }
}
