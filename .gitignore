node_modules/
dist/

# Playwright web-console e2e artifacts
test-results/
playwright-report/
.playwright/
*.log
.DS_Store
.pi-workflows-work/

# Durable run store: the journal + history that both the web UI (`work serve`)
# and the CLI (`work run`, resumable via `--resume <id>`) write under a workspace.
**/.workflows/db/

# Local provider/model config (holds API keys). Commit the *.example.json instead.
work.json

# Installed skills: track only the lockfile (skills-lock.json), not the vendored
# skill content or local Claude settings. Reinstall from the lock to restore.
.agents/
.claude/

# Design-review screenshots are ephemeral verification artifacts (regenerated on
# demand via headless Chrome); keep the markdown reports, drop the PNGs.
.design-review/shots/

# Review-loop: only the curated accepted-findings baseline is committed; anything
# else under .review/ is local scratch.
.review/*
!.review/accepted.md

.env.grafana-cloud
