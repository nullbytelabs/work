# Quieten install output. Deep transitive deps emit deprecation/peer warnings we
# can't fix without forking (e.g. node-domexception via the pi agent's
# fetch-blob → node-fetch chain). npm has no per-warning filter, so we log at
# error level: real failures still surface and the install still fails on them;
# only warn-level noise (deprecations, peer hints, funding) is hidden.
#   To see the warnings again for one command: npm install --loglevel=warn
loglevel=error
fund=false
