{
  "name": "@nullbytelabs/work",
  "version": "0.2.0",
  "description": "Run any workflow on your own machine — YAML jobs in a DAG, each isolated in a secure gondolin micro-VM, with durable runs and optional AI agent steps.",
  "author": "dydx",
  "license": "MIT",
  "type": "module",
  "bin": {
    "work": "./bin/work.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=23.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nullbytelabs/work.git"
  },
  "scripts": {
    "start": "node --experimental-strip-types --disable-warning=ExperimentalWarning src/cli.ts",
    "hello": "node --experimental-strip-types --disable-warning=ExperimentalWarning src/cli.ts ./test/e2e/hello-world-gondolin/workflow.yaml",
    "test": "node --experimental-strip-types --disable-warning=ExperimentalWarning --test test/*.test.ts",
    "test:unit": "WORK_SKIP_VM=1 node --experimental-strip-types --disable-warning=ExperimentalWarning --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "knip": "knip",
    "fan-in": "node scripts/fan-in.mjs",
    "mutation": "node scripts/mutation-check.mjs",
    "check": "npm run lint && npm run typecheck && npm run knip && npm run fan-in",
    "build": "node scripts/build.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@electric-sql/pglite-socket": "^0.2.1",
    "absurd-sdk": "0.4.0",
    "pg": "^8.21.0",
    "yaml": "^2.5.1"
  },
  "optionalDependencies": {
    "@earendil-works/gondolin": "^0.12.0",
    "@earendil-works/pi-coding-agent": "^0.79.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.11.10",
    "esbuild": "^0.25.0",
    "eslint": "^10.4.1",
    "globals": "^16.0.0",
    "knip": "6.16.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.60.0"
  }
}
