{
  "name": "@nullbytelabs/work",
  "version": "0.1.2",
  "description": "Run GitHub-Actions-style workflows locally — each job isolated in a secure gondolin micro-VM, with optional AI agent steps.",
  "author": "dydx",
  "license": "MIT",
  "type": "module",
  "bin": {
    "work": "./bin/pi-workflows.mjs",
    "workflow": "./bin/pi-workflows.mjs",
    "pi-workflows": "./bin/pi-workflows.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=23.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nullbytelabs/pi-workflows.git"
  },
  "scripts": {
    "start": "node --experimental-strip-types --disable-warning=ExperimentalWarning src/cli.ts",
    "hello": "node --experimental-strip-types --disable-warning=ExperimentalWarning src/cli.ts ./test/e2e/hello-world-gondolin/workflow.yaml",
    "test": "node --experimental-strip-types --disable-warning=ExperimentalWarning --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "node scripts/build.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@electric-sql/pglite-socket": "^0.1.6",
    "absurd-sdk": "0.4.0",
    "pg": "^8.21.0",
    "yaml": "^2.5.1"
  },
  "optionalDependencies": {
    "@earendil-works/gondolin": "^0.12.0",
    "@earendil-works/pi-coding-agent": "^0.78.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.11.10",
    "esbuild": "^0.25.0",
    "eslint": "^10.4.1",
    "globals": "^16.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.0"
  }
}
