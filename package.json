{
  "name": "@nullbytelabs/work",
  "version": "0.3.8",
  "description": "Run any workflow on your own machine — YAML jobs in a DAG, each isolated in a secure gondolin micro-VM, with durable runs and optional AI agent steps.",
  "author": "dydx",
  "license": "MIT",
  "type": "module",
  "bin": {
    "work": "./bin/work.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=23.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nullbytelabs/work.git"
  },
  "scripts": {
    "start": "node --experimental-strip-types --disable-warning=ExperimentalWarning src/cli.ts",
    "hello": "node --experimental-strip-types --disable-warning=ExperimentalWarning src/cli.ts ./test/e2e/hello-world-gondolin/workflow.yaml",
    "test": "node --experimental-strip-types --disable-warning=ExperimentalWarning --test-isolation=none --test test/*.test.ts",
    "test:unit": "WORK_SKIP_VM=1 node --experimental-strip-types --disable-warning=ExperimentalWarning --test-isolation=none --test test/*.test.ts",
    "test:web": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "knip": "knip",
    "fan-in": "node scripts/fan-in.mjs",
    "sloc": "node scripts/sloc.mjs",
    "jscpd": "jscpd | awk '/time: [0-9]/{print; exit} {print}'",
    "mutation": "node scripts/mutation-check.mjs",
    "check": "npm run lint && npm run typecheck && npm run knip && npm run fan-in && npm run sloc && npm run jscpd",
    "build": "node scripts/build.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@electric-sql/pglite-socket": "^0.2.1",
    "@opentelemetry/api": "^1.9.1",
    "absurd-sdk": "0.4.0",
    "croner": "^10.0.1",
    "pg": "^8.21.0",
    "yaml": "^2.5.1"
  },
  "optionalDependencies": {
    "@earendil-works/gondolin": "^0.12.0",
    "@earendil-works/pi-coding-agent": "^0.79.1",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.2",
    "@types/pg": "8.20.0",
    "esbuild": "0.28.1",
    "eslint": "10.5.0",
    "fast-check": "4.8.0",
    "globals": "17.6.0",
    "jscpd": "5.0.11",
    "knip": "6.17.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1"
  }
}
